. ********************************************************************************
. *Table 3: The order of the foreach loop is the same as the order of the columns in table 3
. ********************************************************************************
. 
. foreach depvar in lsumemission lsumemission_lma1 lsumemission_lma0 lsumreleases lsumreleas
> es_lma1 lsumreleases_lma0{
  2.         reghdfe `depvar' rggi##treatone rggi##treattwo $control, absorb($absorbvar) vce
> (cluster $clustervar)
  3.                 nlcom (CombinedEffect: _b[1.rggi#1.treatone]+_b[1.rggi#1.treattwo]) (Be
> gin: (exp(_b[1.rggi#1.treatone])-1)*100) (Lower: (exp(_b[1.rggi#1.treattwo])-1)*100) (Tota
> l: (exp(_b[1.rggi#1.treatone]+_b[1.rggi#1.treattwo])-1)*100),post  
  4. }
