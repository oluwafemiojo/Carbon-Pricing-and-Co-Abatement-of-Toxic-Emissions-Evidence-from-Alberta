> attwo#1.dutility]) (Begin: (exp(_b[1.rggi#1.treatone#1.dutility])-1)*100) (Lower: (exp(_b[
> 1.rggi#1.treattwo#1.dutility])-1)*100) (Total: (exp(_b[1.rggi#1.treatone#1.dutility]+_b[1.
> rggi#1.treattwo#1.dutility])-1)*100),post  
  4. }
