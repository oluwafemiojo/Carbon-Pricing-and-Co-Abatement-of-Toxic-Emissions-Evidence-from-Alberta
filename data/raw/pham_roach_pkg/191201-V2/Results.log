. foreach depvar in lsumemission lsumreleases lsumemission_metal1 lsumreleases_metal1 lsumem
> ission_metal0 lsumreleases_metal0{
  2.         reghdfe `depvar' $rggiXy $control, absorb($absorbvar) vce(cluster $clustervar)
  3.         g x = 0
  4.         g y = 0
  5.         g y_hi = 0
  6.         g y_lo = 0
  7.         
.         loc obs 1
  8.         forvalues n=2000/2019{
  9.                 replace x=`n' in `obs'
 10.                 if `n' != $treatyear {
 11.                         replace y    = _b[rggiXy`n']                   in `obs'
 12.                         replace y_hi = _b[rggiXy`n']+1.96*_se[rggiXy`n'] in `obs'
 13.                         replace y_lo = _b[rggiXy`n']-1.96*_se[rggiXy`n'] in `obs'
 14.                 }
 15.                 
.                 if `n' == $treatyear {
 16.                         replace y    = .                 in `obs'
 17.                         replace y_hi = . in `obs'
 18.                         replace y_lo = . in `obs'
 19.                 }
 20.                 
.                 loc obs = `obs' + 1
 21.         }
 22.                 
.         *Graphs:
.         tw (scatter y x in 1/20,lcolor(gs3) mcolor(gs3)) ///
>                         (rspike y_hi y_lo x in 1/20, lcolor(gs3) lstyle(solid)), ///
>                         xtit("") ytit("") ///
>                         yline(0, lcolor(gs10)) ///
>                         xline($treatyear, lcolor(gs10))  ///
>                         xlabel(2000(2)2019, grid glcolor(gs14) glwidth(thin)) ///
>                         ylabel(-3(1)2, grid glcolor(gs14) glwidth(thin)) ///
>                         legend(off) xsize(8) graphr(color(white)) 
 23.         
.         drop x y y_hi y_lo
 24. }
